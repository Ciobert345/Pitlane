{
  "name": "pitlane-desktop",
  "version": "1.0.0",
  "description": "Pitlane F1 Dashboard - app desktop (client + server)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node build.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "app.pitlane.dashboard",
    "productName": "Pitlane",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": ["**/*"]
      },
      {
        "from": "resources/app",
        "to": "app",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.sports"
    },
    "linux": {
      "target": ["AppImage"]
    }
  }
}
